# --- 2. THE RISK ENGINE ---
def check_patient(findings):
    score = 0
    for item in findings:
        if item in BIO_MARKERS:
            score += BIO_MARKERS[item]
    return score

# --- 3. THE INTERACTIVE INTERFACE ---
print("--- Welcome to the Cancer Threat Tracker ---")
print("Please answer 'yes' or 'no' to the following:\n")

user_findings = [] # We start with an empty list (like an empty bag)

# This loop goes through every key in our dictionary
for symptom in BIO_MARKERS:
    # We ask the user a question
    answer = input(f"Do you have {symptom}? (yes/no): ").lower()
    
    # If they say yes, we add that symptom to our 'bag'
    if answer == "yes":
        user_findings.append(symptom)

# Now we run our math function using the symptoms the user typed!
final_score = check_patient(user_findings)

# --- 4. CALCULATING THE TOTAL POSSIBLE SCORE ---
# This looks at every item in your dictionary and adds them up
max_score = sum(BIO_MARKERS.values())

